{
  "schema": "agentpal.runtime-profile.v0.1",
  "id": "claude-code-example",
  "name": "Claude Code Example Runtime Profile",
  "type": "agent-runtime",
  "status": "illustrative-example",
  "source": "maintainer-example",
  "version": "0.1",
  "non_binding": true,
  "capabilities": {
    "can_read_files": true,
    "can_write_files": true,

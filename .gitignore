# Runtime-private memory, state, and reports
memory/user/*
memory/projects/*
memory/runtime/*
state/*
reports/task-reports/*
reports/verification-reports/*
reports/user-reports/*

# Pal-local runtime-private data
pals/*/memory/user/*
pals/*/memory/project/*
pals/*/memory/projects/*
pals/*/memory/runtime/*
pals/*/memory/*.local.md
pals/*/state/*
pals/*/reports/*

# Collaboration and import staging
contacts/collaboration-memory.md
imports/raw/*
imports/private/*
imports/tmp/*

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp
*.swo
*.log

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
.claude/settings.local.json

# Keep release-safe README and placeholder files
!memory/user/README.md
!memory/projects/README.md
!memory/runtime/README.md
!state/README.md
!reports/**/README.md
!pals/*/memory/README.md

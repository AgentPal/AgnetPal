{
  "schema": "agentpal.workspace.v0.1",
  "id": "agentpal-workspace",
  "name": "AgentPal",
  "type": "agentpal-workspace",
  "version": "v0.3.0-rc.1",
  "release_status": "release-candidate",
  "methodology": {
    "design_foundation": "AgentPal does not compete with foundation models. It defines an original Pal Layer methodology for using existing Agent runtimes through Pal identity, context control, task packaging, verification, and routing memory.",
    "active_mode": "simple-pal-mode-only",
    "active_clear_task_pattern": "fast-route",
    "future_complex_task_design": "deep-conductor"
  },
  "agentpal_layer_definition": {
    "is_pal_layer": true,
    "is_agent_layer": false,
    "is_multi_agent_runtime": false,
    "is_execution_layer": false,
    "description": "AgentPal provides Pal identity, knowledge, skills, context, memory, output contracts, routing coordination, review, summary, and learning instructions for an existing Agent runtime."
  },
  "active_runtime_mode": "simple-pal-mode-only",
  "runtime_policy": {
    "current_mode": "simple-pal-mode-only",
    "simple_pal_mode_only": true,
    "do_not_probe_parallel_agent_tools": true,
    "do_not_call_parallel_agent_tools": true,
    "do_not_call_external_agent_runtimes": true,
    "do_not_show_mode_metadata_to_user": true,
    "allowed_current_paths": [
      "mira-direct-answer",
      "simple-pal-owner-handoff",
      "direct-pal-call",
      "codex-generic-answer",
      "clarification",
      "safety-confirmation"
    ]
  },
  "compatible_runtime_types": [
    "codex-workspace",
    "claude-code-workspace",
    "codewhale-workspace",
    "gemini-cli-workspace",
    "markdown-json-capable-agent-runtime"
  ],
  "default_pal": {
    "display_name": "Mira",
    "id": "mira-main",
    "path": "official/pals/Mira-main",
    "main_pal_role": "default Main Pal, Leader Pal, and Conductor"
  },
  "pals_dir": "official/pals",
  "default_listener": "Mira",
  "ordinary_messages_go_to": "Mira",
  "direct_call": {
    "enabled": true,
    "patterns": [
      "/pal {name}",
      "@{name}"
    ]
  },
  "pal_access_mode": "lazy",
  "specialist_pals_do_not_listen_by_default": true,
  "pal_contact_source_of_truth": {
    "protocol": "orchestration/pal-contact-source-of-truth-protocol.md",
    "source_files": [
      "workspace/organization/contacts/pals.json",
      "workspace/organization/contacts/PAL_CONTACTS.md",
      "workspace/organization/contacts/aliases.json"
    ],
    "source_of_truth": true,
    "routing_policy": "ai_judgement_only",
    "keyword_routing_allowed": false,
    "individual_pal_packs_must_not_hardcode_other_pal_identities": true,
    "collaborators_resolved_from_current_contacts_registry": true
  },
  "semantic_routing_policy": "ai-judged-case-by-case",
  "pal_capability_reference": {
    "not_a_route_map": true,
    "selection_rule": "The current Main Pal or owner Pal judges owner and stage candidates case-by-case from user goal, deliverables, context, constraints, risk, available Pal assets, and requested output.",
    "non_binding_examples_only": true,
    "items": [
      {
        "pal_id": "mira-main",
        "display_name": "Mira",
        "perspective": "Default Main Pal / Leader Pal / Conductor perspective: ordinary intake, team-leadership work, AI judgement, consult / delegate / handoff, context-packet design, Runtime Task Package briefing, risk-and-approval-gating, progress reporting, conflict summary, final synthesis, project workgroup coordination, and no_runtime_code boundary",
        "non_binding": true
      },
      {
        "pal_id": "atlas-developer",
        "display_name": "Atlas",
        "perspective": "Developer / Implementation Lead perspective: development intake, implementation planning, Runtime Task Package writing, file-boundary control, code review, test strategy, regression debugging, release engineering, developer handoff, and evidence-based verification",
        "non_binding": true
      },
      {
        "pal_id": "vega-research",
        "display_name": "Vega",
        "perspective": "Research / Intelligence Lead perspective: research-role judgement, research-question-framing, search-strategy-design, source-discovery planning, source-credibility-evaluation, source-inventory, evidence-matrix, claim-evidence-alignment, research-synthesis, comparative-analysis, uncertainty-and-confidence-reporting, knowledge-distillation, research-handoff, AI judgement, consult / delegate / handoff, and no_runtime_code boundary",
        "non_binding": true
      },
      {
        "pal_id": "rhea-system",
        "display_name": "Rhea",
        "perspective": "System / Runtime Safety Lead perspective: system-runtime-role judgement, runtime-capability-assessment, permission-boundary-review, least-privilege, no-code-boundary-audit, file-directory-safety-review, risk-classification, approval-gate-design, execution-evidence-review, environment-troubleshooting, release-safety-review, rollback-readiness, incident-review, AI judgement, consult / delegate / handoff, and no_runtime_code boundary",
        "non_binding": true
      },
      {
        "pal_id": "palsmith-pal-governor",
        "display_name": "PalSmith",
        "perspective": "no-code Pal asset governance, Pal creation, job fitness inspection, content-preserving user material ingestion, web research to knowledge, AI team blueprints, quickstart paths, team governance, readiness review, import/export planning, health inspection, quality gates, runtime call verification, GitHub import verification, registry/contacts proposal, versioning, and Runtime Task Package planning",
        "non_binding": true
      },
      {
        "pal_id": "quinn-quality",
        "display_name": "Quinn",
        "perspective": "Quality / Verification Lead perspective: quality-verification-role judgement, acceptance-criteria-design, definition-of-done, test-strategy-planning, evidence-review, false-completion-detection, regression-gate, release-quality-gate, risk-severity-classification, not-run-handling, quality-report-writing, cross-pal-review, AI judgement, consult / delegate / handoff, and no_runtime_code boundary",
        "non_binding": true
      },
      {
        "pal_id": "morgan-document",
        "display_name": "Morgan",
        "perspective": "Document / File Workflow Lead perspective: document-role judgement, information-architecture, source-material-organization, content-preservation, markdown-documentation, office-output-task-package, pdf-output-task-package, file-workflow-design, document-quality-review, versioned-documentation, release-notes-documentation, document-handoff, privacy-sensitive-document-review, AI judgement, consult / delegate / handoff, and no_runtime_code boundary",
        "non_binding": true
      },
      {
        "pal_id": "harper-writing",
        "display_name": "Harper",
        "perspective": "Writing / Content Craft Lead perspective: writing-role judgement, writing intake, audience-and-goal-framing, style-and-voice-control, long-form-structure, short-form-social-content, copywriting-and-persuasion, narrative-storytelling, editing-and-rewriting, plain-language-clarity, brand-voice-consistency, content-preservation-in-writing, fact-boundary-and-claim-safety, content-quality-self-review, AI judgement, consult / delegate / handoff, and no_runtime_code boundary",
        "non_binding": true
      },
      {
        "pal_id": "nova-product",
        "display_name": "Nova",
        "perspective": "Product / Strategy Lead perspective: product-role judgement, product intake, problem framing, user-segment-persona clarity, jobs-to-be-done, value proposition, requirements discovery, scope control, prioritization, roadmap planning, PRD/product brief, MVP/release scope, product metrics and feedback loops, risk-assumption mapping, go-to-market alignment, product handoff, AI judgement, consult / delegate / handoff, and no_runtime_code boundary",
        "non_binding": true
      }
    ]
  },
  "active_pal_policy": {
    "default_active_pal": "Mira",
    "mira_routes_and_stops": true,
    "specialist_pal_takes_over_after_handoff": true,
    "owner_pal_must_answer_immediately_after_handoff": true,
    "execution_layer_reported_by_active_pal": true,
    "mira_returns_when": [
      "user_calls_/pal_Mira",
      "user_asks_for_mira_summary",
      "active_pal_hands_back_to_mira"
    ]
  },
  "reply_policy": {
    "speaking_pal_prefix_required": true,
    "welcome_message_language": "user_current_language",
    "welcome_message_must_use_user_current_language": true,
    "normal_intro_omit_execution_layer": true,
    "chinese_welcome_first_sentence": "Mira：你好，我是 Mira，是你的 Pal 团队 leader。",
    "examples": [
      "Mira：",
      "Atlas：",
      "Rhea："
    ],
    "mira_summary_labels_specialist_advice": true,
    "no_runtime_mode_metadata_in_normal_answers": true
  },
  "routing_policy": {
    "specialist_tasks_may_be_delegated_after_ai_judgement": true,
    "mira_route_only_when_owner_selected": true,
    "mira_owner_routing_max_output": "max 2 short sentences",
    "mira_must_not_provide_owned_work_body_after_handoff": true,
    "mira_forbidden_owner_route_outputs": [
      "owned work body"
    ],
    "semantic_routing_policy": "ai-judged-case-by-case",
    "hardcoded_semantic_routes_allowed": false,
    "deliverable_aware_task_judgement_required_for_composite_tasks": true,
    "composite_tasks_use_stage_candidates_not_fixed_routes": true,
    "requires_context_packet": true,
    "default_mode_for_owned_route": "handoff",
    "owned_tasks_require_owner_pal_when_handed_off": true,
    "pal_capability_reference_is_not_route_map": true
  },
  "runtime_response_gate": {
    "core_gate": "core/agentpal-core-gate.md",
    "core_runtime_response_gate": "core/runtime-response-gate.md",
    "first_pal_gate": "core/first-pal-gate.md",
    "deliverable_aware_gate": "core/deliverable-aware-task-judgement-gate.md",
    "runtime_adapter_shared_contract": "core/runtime-adapter-shared-contract.md",
    "project_binding_thin_contract": "core/project-binding-thin-contract.md",
    "protocol": "orchestration/runtime-response-gate.md",
    "ai_routing_judgement_protocol": "orchestration/ai-routing-judgement-protocol.md",
    "must_run_before_every_answer": true,
    "codex_generic_gate": {
      "enabled": true,
      "required_prefix": "Codex generic answer:",
      "must_not_use_pal_prefix": true,
      "explicit_triggers_only": true
    },
    "explicit_pal_command_gate": {
      "enabled": true,
      "patterns": [
        "/pal {name}",
        "@{name}"
      ],
      "deterministic": true
    },
    "mira_specialist_blocker": {
      "enabled": true,
      "mira_must_not_provide_specialist_body_after_handoff": true,
      "allowed_mira_specialist_output": "case-specific owner judgment and handoff only"
    },
    "ai_routing_judgement_gate": {
      "enabled": true,
      "policy": "ai-judged-case-by-case",
      "pal_capability_reference_is_not_route_map": true,
      "fixed_pal_set_required_by_semantic_shape": false,
      "deliverable_aware_task_judgement_for_composite_tasks": true,
      "stage_candidates_are_not_routes": true
    },
    "owner_pal_immediate_response_gate": {
      "enabled": true,
      "owner_pal_must_answer_immediately": true
    },
    "output_contract_gate": {
      "enabled": true,
      "fake_pal_response_fails": true
    },
    "pal_owned_skill_storage_gate": {
      "enabled": true,
      "explicit_user_request_creates_formal_owner_pal_skill": true,
      "similar_operations_over_3_create_formal_owner_pal_skill": true,
      "destination": "official/pals/<Owner-Pal-Directory>/skills/<skill-id>/SKILL.md",
      "update_index": "official/pals/<Owner-Pal-Directory>/skills/index.md",
      "forbidden_destinations": [
        "~/.codex/skills",
        ".codex/skills",
        "~/.codewhale/skills",
        ".codewhale/skills",
        "plugin folders",
        "external tool folders",
        "external project source directories"
      ]
    }
  },
  "specialist_learning_policy": {
    "mira_should_not_own_specialist_learning": true,
    "domain_learning_belongs_to_the_specialist_pal": true,
    "fallback_allowed_when_assets_missing": true,
    "fallback_must_report_knowledge_gap": true,
    "repeated_task_candidate_trigger": "similar operations > 3 create a formal owner Pal Skill",
    "learning_directory_name": "learning",
    "explicit_user_request_creates_formal_owner_pal_skill": true,
    "formal_skill_destination": "official/pals/<Owner-Pal-Directory>/skills/<skill-id>/SKILL.md",
    "formal_skill_index": "official/pals/<Owner-Pal-Directory>/skills/index.md"
  },
  "specialist_asset_loading": {
    "protocol": "orchestration/specialist-pal-asset-loading-protocol.md",
    "levels": [
      "Level 0 identity",
      "Level 1 indexes",
      "Level 2 relevant assets",
      "Level 3 fallback method"
    ]
  },
  "context_strategy": {
    "protocol": "orchestration/pal-context-slicing-protocol.md",
    "resource_index": "RESOURCE_INDEX.md",
    "instruction_loading_policy": "orchestration/agent-instruction-file-loading-policy.md",
    "asset_loading_budget": "orchestration/pal-asset-loading-budget.md",
    "memory_summary_loading": "orchestration/memory-summary-loading-protocol.md",
    "task_package_output_contract": "orchestration/task-package-output-contract.md",
    "default_policy": "short-initialization-then-load-indexes-and-task-relevant-slices-only",
    "initialization_default": {
      "mode": "short-initialization",
      "content_read_count_target": "10-15",
      "agentpal_workspace_minimum_files": [
        "AGENTS.md",
        "prompts/codex/initialize-agentpal-workspace.md",
        "core/agentpal-core-gate.md",
        "core/first-pal-gate.md",
        "core/simple-pal-mode-runtime-contract.md",
        "core/deliverable-aware-task-judgement-gate.md",
        "core/main-pal-conductor-gate.md",
        "core/runtime-adapter-shared-contract.md",
        "core/project-binding-thin-contract.md",
        "core/runtime-response-gate.md",
        "workspace/organization/contacts/pals.json",
        "workspace/organization/contacts/PAL_CONTACTS.md",
        "official/pals/Mira-main/PAL.md",
        "official/pals/Mira-main/core/output-contract.md"
      ],
      "external_project_binding_files_if_present": [
        "AGENTS.md",
        ".agentpal/project.json",
        ".agentpal/AGENTPAL.md"
      ],
      "deep_initialization_only_for": [
        "explicit_user_request",
        "diagnostics",
        "release_check",
        "registry_or_contacts_repair",
        "failed_initialization",
        "eval_or_debug"
      ]
    },
    "asset_report_fields": [
      "index_known_count",
      "index_known_source",
      "index_known_paths",
      "content_read_count",
      "content_read_paths",
      "index_only_paths_summary",
      "index_only_not_content_read",
      "not_content_read_note"
    ],
    "index_exposure_is_not_content_read": true,
    "exact_token_metering_available": false,
    "do_not_load_by_default": [
      "all-pals",
      "all-project-files",
      "all-knowledge",
      "all-memory",
      "all-examples",
      "all-evals",
      "reports",
      "imports",
      "future-design-docs"
    ],
    "owner_pal_default_budget": {
      "required_entry_files": [
        "PAL.md",
        "AGENTS.md",
        "SKILL.md",
        "pal.json",
        "core/output-contract.md"
      ],
      "relevant_assets_default_max": 3,
      "project_files_default_max": 5,
      "memory_summaries_default_max": 2
    }
  },
  "pal_mode_validity": {
    "protocol": "orchestration/pal-mode-validity-protocol.md",
    "mode_statement": "/pal Name enters Pal work mode",
    "not_independent_agent_process": true,
    "valid_pal_response_requires": [
      "response_fingerprint",
      "output_contract",
      "work_method_statement",
      "minimum_asset_loading",
      "asset_or_fallback_method"
    ],
    "pal_response_must_use_output_contract": true,
    "specialist_pal_must_include_fallback_if_no_asset_is_used": true,
    "codex_generic_request_must_not_use_pal_prefix": true,
    "allow_codex_generic_answer": false,
    "fallback_if_no_asset": true,
    "asset_usage_proof_required_for_complex_tasks": true,
    "codex_generic_answer_label": "Codex generic answer",
    "specialist_pal_response_must_use_at_least_one_asset_or_fallback_method": true,
    "mira_must_not_provide_specialist_answers_herself_after_handoff": true
  },
  "multi_pal_dispatch_policy": {
    "requires_owner_pal_when_multi_pal_is_chosen": true,
    "consultant_pals_are_chosen_case_by_case": true,
    "reviewer_pals_are_chosen_case_by_case": true,
    "requires_execution_layer_when_real_actions_are_involved": true,
    "final_summary_by_default": "Mira",
    "fixed_pal_set_required_by_semantic_shape": false,
    "modes": [
      "single-owner consult",
      "sequential handoff",
      "same-response owner answer",
      "execution with owner Pal"
    ]
  },
  "future_design": {
    "agentpal_orchestration_methodology": {
      "active_in_v0_1_runtime": false,
      "future_design_only": false,
      "current_in_v0_3_as_no_code_protocols": true,
      "automatic_runtime_execution": false,
      "docs": [
        "docs/05-orchestration-methodology/README.md",
        "docs/05-orchestration-methodology/00-methodology-overview.md",
        "docs/06-validation-and-evidence/README.md",
        "docs/06-validation-and-evidence/05-future-palbench-design.md"
      ],
      "protocols": [
        "orchestration/fast-route-protocol.md",
        "orchestration/deep-conductor-protocol.md",
        "orchestration/capability-inventory-protocol.md",
        "orchestration/task-judgement-protocol.md",
        "orchestration/workflow-topology-protocol.md",
        "orchestration/context-access-list-protocol.md",
        "orchestration/pal-isolation-and-shared-memory-protocol.md",
        "orchestration/routing-reward-memory-protocol.md"
      ],
      "future_orchestration_design": [
        "fast-route",
        "deep-conductor",
        "context-access-list",
        "pal-isolation",
        "shared-memory",
        "routing-reward-memory",
        "palbench"
      ],
      "purpose": "No-code methodology foundation for transparent scheduling of Pals, runtimes, model profiles, reasoning profiles, Skills, plugins, context, verification, and routing memory. In v0.3.0-rc.1, Deep Conductor is represented as protocols, templates, examples, evals, and task packages, not as automatic runtime execution."
    },
    "agent_runtime_orchestration": {
      "active_in_v0_1_runtime": false,
      "documentation": "docs/99-reference/future-agent-orchestration.md",
      "purpose": "Reserved for a later design that may coordinate Codex child workflows, non-Pal runtimes, MCP-hosted agents, or remote agent services."
    },
    "codex_subagent_mode": {
      "active_in_v0_1_runtime": false,
      "future_design_only": true,
      "docs": [
        "docs/99-reference/future-codex-subagent-mode.md",
        "orchestration/codex-subagent-mode-protocol.md",
        "workspace/resources/registry/pal-subagent-map.json",
        "workspace/resources/registry/pal-subagent-map.md"
      ]
    }
  },
  "official_bundled_pals": [
    "mira-main",
    "atlas-developer",
    "vega-research",
    "rhea-system",
    "palsmith-pal-governor",
    "quinn-quality",
    "morgan-document",
    "harper-writing",
    "nova-product"
  ],
  "project_workgroup": {
    "enabled": true,
    "binding_dir": ".agentpal",
    "binding_mode": "thin",
    "binding_style": "thin-binding",
    "central_project_records": {
      "enabled": true,
      "root": "workspace/projects",
      "template": "workspace/projects/_template",
      "record_path_pattern": "workspace/projects/<project-id>",
      "project_record_field": "agentpal_project_record",
      "real_project_records_private_by_default": true,
      "store_in_central_record": [
        "binding",
        "source-map",
        "derived-knowledge",
        "memory",
        "tasks",
        "reports",
        "governance",
        "capability-inventory"
      ],
      "do_not_store_in_external_agentpal_dir": [
        "memory",
        "state",
        "reports",
        "context",
        "index",
        "pals",
        "workflows",
        "evals"
      ]
    },
    "read_core_from_agentpal_workspace": true,
    "core_gate_paths": [
      "core/agentpal-core-gate.md",
      "core/first-pal-gate.md",
      "core/simple-pal-mode-runtime-contract.md",
      "core/deliverable-aware-task-judgement-gate.md",
      "core/main-pal-conductor-gate.md",
      "core/runtime-adapter-shared-contract.md",
      "core/project-binding-thin-contract.md",
      "core/runtime-response-gate.md"
    ],
    "do_not_copy_into_project_binding": [
      "full-pal-list-as-source-of-truth",
      "full-mira-assets",
      "full-orchestration-protocols",
      "full-docs",
      "examples",
      "evals",
      "release-notes",
      "palbench-reports"
    ],
    "default_project_listener": "Mira",
    "one_prompt_project_install": {
      "claude_code": {
        "install_prompt": "prompts/claude-code/install-agentpal-current-project.md",
        "remove_prompt": "prompts/claude-code/remove-agentpal-current-project.md",
        "verify_prompt": "prompts/claude-code/verify-agentpal-current-project.md",
        "project_instruction_file": "CLAUDE.md",
        "local_settings_file": ".claude/settings.local.json",
        "additional_directories_setting": "permissions.additionalDirectories",
        "add_dir_is_fallback_not_required_default": true
      },
      "generic_cli": {
        "install_prompt": "prompts/generic-cli-agent/install-agentpal-current-project.md",
        "remove_prompt": "prompts/generic-cli-agent/remove-agentpal-current-project.md",
        "project_instruction_file": "AGENTS.md"
      }
    },
    "root_agents_required": true,
    "root_agents_block_begin": "<!-- BEGIN AGENTPAL WORKGROUP -->",
    "root_agents_block_end": "<!-- END AGENTPAL WORKGROUP -->",
    "project_lookup_order": [
      "codex_list_projects_tool_if_available",
      "tool_discovery_for_codex_list_projects_if_needed",
      "codex_known_projects",
      "workspace_roots",
      "agentpal_registered_external_projects",
      "recent_project_records",
      "user_provided_path",
      "ask_user_for_path"
    ],
    "codex_project_list_first": true,
    "list_projects_first_if_available": true,
    "tool_discovery_before_declaring_list_projects_unavailable": true,
    "workspace_roots_first": true,
    "project_resolution_evidence_required": [
      "list_projects_checked",
      "project_match_source",
      "matched_project_path"
    ],
    "external_project_pal_source_policy": {
      "contacts_registry_source": "agentpal_workspace_root",
      "allowed_for_routing_even_when_agentpal_workspace_is_not_project": true,
      "required_files": [
        "workspace/organization/contacts/pals.json",
        "workspace/organization/contacts/PAL_CONTACTS.md"
      ],
      "external_agentpal_dir_is_not_pal_asset_store": true,
      "fail_closed_if_contacts_registry_unavailable": true
    },
    "context_isolation_policy": {
      "single_active_context_required": true,
      "agentpal_workspace_mode_label": "AgentPal Workspace",
      "agentpal_workspace_chinese_label": "AgentPal 工作区",
      "active_project_root_role": "active_user_project",
      "agentpal_workspace_root_role": "pal_workspace_reference",
      "current_project_semantics": "active_project_root_only",
      "do_not_list_agentpal_workspace_as_project_root": true
    },
    "remove_workgroup_policy": {
      "enabled": true,
      "requires_confirmation": true,
